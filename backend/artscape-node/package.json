{
  "name": "@artscape/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "report:sample": "tsx scripts/generate-sample-report.ts",
    "backup": "tsx scripts/backup.ts",
    "uat:v1": "tsx scripts/uat-backend-v1.ts",
    "uat:v1:restart": "tsx scripts/uat-restart-check.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.864.0",
    "@hypha/adapters-local": "file:../../Hypha/packages/adapters-local",
    "@hypha/core": "file:../../Hypha/packages/core",
    "@hypha/domain": "file:../../Hypha/packages/domain",
    "@hypha/fsm": "file:../../Hypha/packages/fsm",
    "@hypha/harness": "file:../../Hypha/packages/harness",
    "@hypha/inference": "file:../../Hypha/packages/inference",
    "@hypha/kernel": "file:../../Hypha/packages/kernel",
    "@hypha/mcp": "file:../../Hypha/packages/mcp",
    "@hypha/memory": "file:../../Hypha/packages/memory",
    "@hypha/models": "file:../../Hypha/packages/models",
    "@hypha/serving-cache": "file:../../Hypha/packages/serving-cache",
    "@hypha/skills": "file:../../Hypha/packages/skills",
    "@hypha/storage": "file:../../Hypha/packages/storage",
    "@hypha/tools": "file:../../Hypha/packages/tools",
    "cors": "^2.8.5",
    "bullmq": "^5.58.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.5",
    "multer": "^2.0.2",
    "pdfkit": "^0.17.2",
    "pino": "^9.7.0",
    "prom-client": "^15.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.9",
    "@types/pdfkit": "^0.17.2",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^8.57.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
