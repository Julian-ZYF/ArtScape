# Backend address used by the Vite development proxy.
ARTSCAPE_API_URL=http://localhost:3100

# Development only. Keep the value aligned with the local backend JWT_SECRET.
# It is read by Vite's Node process and is never bundled into browser code.
ARTSCAPE_DEMO_JWT_SECRET=replace-with-your-local-jwt-secret
ARTSCAPE_DEMO_USER_ID=artscape-demo-owner
JWT_ISSUER=artscape
JWT_AUDIENCE=artscape-api
